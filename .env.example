# 复制为 .env 并填值(.env 不会进 git)

# 模型 API(国内主力,免费额度多,适合练手)
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=        # 通义千问 Qwen
LLM_MODEL=deepseek-chat   # ⚠️ deepseek-chat 将于 2026-07-24 退役,去控制台确认当前名(可能 deepseek-v4-flash)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# 向量库(主用 Milvus;轻量可改 pgvector)
MILVUS_URI=http://localhost:19530
# PGVECTOR_DSN=postgresql+psycopg://user:pwd@localhost:5432/findoc

# 可观测
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# embedding / rerank 模型
EMBEDDING_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
