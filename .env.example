# 复制为 .env 并填值(.env 不会进 git)

# 当前已接入的模型 API
DEEPSEEK_API_KEY=
LLM_MODEL=deepseek-v4-flash

# 预留 provider，当前代码尚未接入
DASHSCOPE_API_KEY=        # 通义千问 Qwen
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# 向量库(主用 Milvus;轻量可改 pgvector)
MILVUS_URI=http://localhost:19530
# PGVECTOR_DSN=postgresql+psycopg://user:pwd@localhost:5432/findoc

# 可观测
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# embedding / rerank 模型
EMBEDDING_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
